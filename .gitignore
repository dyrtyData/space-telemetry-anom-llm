# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Raw ESA-AD data (multi-GB; lives on external drive or data/raw/)
data/raw/esa-ad/ESA-Mission*
data/raw/**/*.zip

# Processed / derived artifacts (regenerated by the ETL)
data/processed/jsonl/*.jsonl
data/processed/plots/**/*.png
data/processed/plots/**/*.json
data/processed/plots/*_metadata.jsonl
data/splits/*.jsonl
data/formatted/
data/labels/*.json

# Models (large binaries -- stay on DUAL DRIVE / HF, never in git)
models/lora/
models/merged/
models/gguf/
models/lstm/

# Phase 16 (mini-FOXES): torch checkpoints are binaries, regenerable from run.py; keep them
# out of git like the other model weights. metrics.json IS tracked (it's the small product).
results/foxes_repro/*.pt
results/foxes_repro/*.pt.tmp

# Results ARE tracked: eval JSONs + the comparison report are the product (≈3.5 MB total,
# and several cost hours of model inference to regenerate). Only transient run logs are
# ignored. (Previously results/**/*.json + results/*.md were ignored as "regenerable" —
# reverted 2026-06-14: re-running inference to recover them is not acceptable.)

# Phase 14: the LSTM dense per-window error dump (~9 MB) and its throwaway metrics file are
# cheap to regenerate (~6 min, `make lstm-window-scores`, reuses saved models), so they are
# NOT tracked — unlike the hours-long inference results above. The ensemble consumes them.
results/lstm/window_scores.json
results/lstm/baseline_results_scoredump.json

# Transient run logs
*.log
results/.*.log

# Kaggle credentials (never commit)
kaggle.json
access_token

# Keep empty dir structure
!**/.gitkeep

.env
FinalReport_FollowUp.md
FinalReport11-14_FollowUp.md

# NotebookLM video (65 MB, too large for git — hosted via NotebookLM link)
thoughts/shared/notebookLM/*.mp4