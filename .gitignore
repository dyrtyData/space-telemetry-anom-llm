# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Raw ESA-AD data (multi-GB; lives on external drive or data/raw/)
data/raw/esa-ad/ESA-Mission*
data/raw/**/*.zip

# Processed / derived artifacts (regenerated by the ETL)
data/processed/jsonl/*.jsonl
data/processed/plots/**/*.png
data/processed/plots/**/*.json
data/processed/plots/*_metadata.jsonl
data/splits/*.jsonl
data/formatted/
data/labels/*.json

# Models & results
models/lora/
models/merged/
models/gguf/
models/lstm/
results/**/*.json
results/*.md

# Kaggle credentials (never commit)
kaggle.json
access_token

# Keep empty dir structure
!**/.gitkeep
